{
  "@context": {
    "@version": 1.1,
    "keyspaces": "https://keyspaces.amazonaws.com/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Keyspace": "keyspaces:Keyspace",
    "Table": "keyspaces:Table",
    "id": {
      "@id": "schema:identifier",
      "@type": "xsd:string"
    },
    "name": {
      "@id": "schema:name",
      "@type": "xsd:string"
    },
    "description": {
      "@id": "schema:description",
      "@type": "xsd:string"
    },
    "status": {
      "@id": "keyspaces:status",
      "@type": "xsd:string"
    },
    "arn": {
      "@id": "keyspaces:arn",
      "@type": "xsd:string"
    },
    "createdAt": {
      "@id": "schema:dateCreated",
      "@type": "xsd:dateTime"
    },
    "updatedAt": {
      "@id": "schema:dateModified",
      "@type": "xsd:dateTime"
    }
  }
}