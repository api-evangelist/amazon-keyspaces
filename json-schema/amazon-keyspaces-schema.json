{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.apievangelist.com/amazon-keyspaces/table-definition",
  "title": "Amazon Keyspaces Table Definition",
  "description": "Schema defining the structure of an Amazon Keyspaces (for Apache Cassandra) table resource, including schema definition, capacity mode, encryption, and point-in-time recovery settings.",
  "type": "object",
  "required": [
    "keyspaceName",
    "tableName",
    "schemaDefinition"
  ],
  "properties": {
    "keyspaceName": {
      "type": "string",
      "description": "The name of the keyspace that the table belongs to.",
      "minLength": 1,
      "maxLength": 48,
      "pattern": "^[a-zA-Z0-9_]+$"
    },
    "tableName": {
      "type": "string",
      "description": "The name of the table.",
      "minLength": 1,
      "maxLength": 48,
      "pattern": "^[a-zA-Z0-9_]+$"
    },
    "resourceArn": {
      "type": "string",
      "description": "The Amazon Resource Name (ARN) of the table."
    },
    "status": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "CREATING",
        "UPDATING",
        "DELETING",
        "DELETED",
        "RESTORING",
        "INACCESSIBLE_ENCRYPTION_CREDENTIALS"
      ],
      "description": "The current status of the table."
    },
    "schemaDefinition": {
      "$ref": "#/$defs/SchemaDefinition"
    },
    "capacitySpecification": {
      "$ref": "#/$defs/CapacitySpecification"
    },
    "encryptionSpecification": {
      "$ref": "#/$defs/EncryptionSpecification"
    },
    "pointInTimeRecovery": {
      "$ref": "#/$defs/PointInTimeRecovery"
    },
    "ttl": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ENABLED"
          ],
          "description": "Whether TTL is enabled."
        }
      },
      "description": "Time-to-live settings for the table."
    },
    "defaultTimeToLive": {
      "type": "integer",
      "minimum": 0,
      "description": "Default TTL value in seconds for the table."
    },
    "comment": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "description": "A description of the table."
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "key": {
            "type": "string"
          },
          "value": {
            "type": "string"
          }
        }
      },
      "description": "Tags associated with the table."
    },
    "creationTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "The timestamp when the table was created."
    }
  },
  "$defs": {
    "SchemaDefinition": {
      "type": "object",
      "description": "The schema definition for the table.",
      "required": [
        "allColumns",
        "partitionKeys"
      ],
      "properties": {
        "allColumns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "type"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "The name of the column."
              },
              "type": {
                "type": "string",
                "description": "The data type of the column (e.g., text, int, bigint, timestamp, uuid, blob)."
              }
            }
          },
          "description": "All columns in the table."
        },
        "partitionKeys": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "description": "The columns used as partition keys."
        },
        "clusteringKeys": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "orderBy": {
                "type": "string",
                "enum": [
                  "ASC",
                  "DESC"
                ]
              }
            }
          },
          "description": "The columns used as clustering keys."
        },
        "staticColumns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              }
            }
          },
          "description": "Static columns in the table."
        }
      }
    },
    "CapacitySpecification": {
      "type": "object",
      "description": "The capacity mode and throughput settings.",
      "required": [
        "throughputMode"
      ],
      "properties": {
        "throughputMode": {
          "type": "string",
          "enum": [
            "PAY_PER_REQUEST",
            "PROVISIONED"
          ],
          "description": "The throughput capacity mode."
        },
        "readCapacityUnits": {
          "type": "integer",
          "minimum": 1,
          "description": "Provisioned read capacity units."
        },
        "writeCapacityUnits": {
          "type": "integer",
          "minimum": 1,
          "description": "Provisioned write capacity units."
        }
      }
    },
    "EncryptionSpecification": {
      "type": "object",
      "description": "Encryption settings for the table.",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "AWS_OWNED_KMS_KEY",
            "CUSTOMER_MANAGED_KMS_KEY"
          ],
          "description": "The encryption type."
        },
        "kmsKeyIdentifier": {
          "type": "string",
          "description": "The KMS key ARN for customer managed encryption."
        }
      }
    },
    "PointInTimeRecovery": {
      "type": "object",
      "description": "Point-in-time recovery settings.",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ENABLED",
            "DISABLED"
          ],
          "description": "Whether point-in-time recovery is enabled."
        },
        "earliestRestorableTimestamp": {
          "type": "string",
          "format": "date-time",
          "description": "The earliest point-in-time restore timestamp."
        }
      }
    }
  }
}
